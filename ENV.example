# 将本文件复制为 N_Agent/.env 并填入真实值（已在 .gitignore 中忽略 .env），
# 程序会在导入 config_llm 时自动读取；也可直接在终端 export：
#
#   export NOVEL_AGENT_API_KEY="你的密钥"
#   export PYTHONPATH="$(pwd)/src"
#
# NOVEL_AGENT_API_KEY=sk-xxxxxxxx
# NOVEL_AGENT_BASE_URL=https://ai.nengyongai.cn/v1
# NOVEL_AGENT_MODEL=deepseek-v3-250324
#
# 也可使用通用变量名（与 OpenAI 兼容客户端一致）：
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_BASE_URL=https://ai.nengyongai.cn/v1
